type Timestamp = nat;
type LxmfHash = text;
type HtlcStatus = 
 variant {
   Locked;
   Refunded;
   Released;
 };
type HtlcRecord = 
 record {
   amount: nat;
   expiry: Timestamp;
   id: HtlcId;
   paymentHash: text;
   receiverLxmfHash: LxmfHash;
   senderLxmfHash: LxmfHash;
   status: HtlcStatus;
 };
type HtlcId = text;
type EventLogEntry = text;
service : {
  __balances: () -> (reserved) query;
  __eventLog: (io: opt nat, count: opt nat) -> (vec EventLogEntry) query;
  __htlcs: () -> (reserved) query;
  __nextHtlcId: () -> (reserved) query;
  __publicKeys: () -> (reserved) query;
  deposit: (lxmfHash: LxmfHash, amount: nat) -> ();
  getBalance: (lxmfHash: LxmfHash) -> (nat) query;
  getHTLC: (htlcId: HtlcId) -> (opt HtlcRecord) query;
  getRegisteredPublicKey: (lxmfHash: LxmfHash) -> (opt text) query;
  listHTLCsForAddress: (lxmfHash: LxmfHash) -> (vec HtlcRecord) query;
  lockHTLC: (senderLxmfHash: LxmfHash, receiverLxmfHash: LxmfHash, amount:
   nat, paymentHash: text, expirySeconds: nat, signature: text) -> (HtlcId);
  refundHTLC: (htlcId: HtlcId) -> ();
  registerPublicKey: (lxmfHash: LxmfHash, publicKeyHex: text) -> ();
  releaseHTLC: (htlcId: HtlcId, preimage: text) -> ();
}
